{
  "name": "comfort-counsel",
  "version": "1.0.0",
  "description": "Youth counseling platform MVP",
  "main": "server/server.js",
  "scripts": {
    "start": "set NODE_OPTIONS=--dns-result-order=ipv4first&& node server/server.js",
    "dev": "set NODE_OPTIONS=--dns-result-order=ipv4first&& nodemon server/server.js",
    "test": "mocha 'server/**/*.test.js'",
    "test:watch": "mocha 'server/**/*.test.js' --watch",
    "db:check": "node check-database-status.js",
    "db:wake": "node wake-database.js",
    "db:test": "set NODE_OPTIONS=--dns-result-order=ipv4first&& node test-simple-connection.js",
    "db:diagnose": "set NODE_OPTIONS=--dns-result-order=ipv4first&& node test-db-diagnostic.js"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.3",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "fast-check": "^4.7.0",
    "mocha": "^11.7.5",
    "nodemon": "^3.0.2",
    "sinon": "^21.1.2",
    "supertest": "^7.2.2"
  }
